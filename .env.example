# ============================================================================
# Variables de entorno del backend
# ============================================================================
# Para desarrollo local copiá este archivo a `.env` y editá los valores.
# Para producción configurá las variables en el orquestador (systemd unit,
# docker-compose, k8s ConfigMap/Secret, etc.). NO commitees `.env` con
# valores reales.

# --- Conexión a SQL Server --------------------------------------------------
# Requiere "ODBC Driver 18 for SQL Server" instalado en el host
# (macOS: `brew tap microsoft/mssql-release && brew install msodbcsql18`;
#  Linux:  ver instrucciones oficiales de Microsoft).
#
# Formato SQLAlchemy URL — el código deriva el DSN sync (pyodbc) automáticamente
# si DATABASE_URL_SYNC no está seteado. Recordá url-encodear `!` como `%21`, etc.
DATABASE_URL=mssql+aioodbc://sa:Fonplata2027%21@localhost:1433/presupuesto2027?driver=ODBC+Driver+18+for+SQL+Server&Encrypt=no&TrustServerCertificate=yes

# Alternativa: cadena ODBC nativa (sin prefijo "://"). El backend la envuelve
# en `mssql+aioodbc:///?odbc_connect=...` para SQLAlchemy.
# DATABASE_URL=Driver={ODBC Driver 18 for SQL Server};Server=localhost,1433;Database=presupuesto2027;UID=sa;PWD=Fonplata2027!;Encrypt=no;TrustServerCertificate=yes

# Opcional: override explícito del DSN sync (Alembic / scripts). Si se omite,
# se deriva del DATABASE_URL anterior reemplazando aioodbc → pyodbc.
# DATABASE_URL_SYNC=mssql+pyodbc://sa:Fonplata2027%21@localhost:1433/presupuesto2027?driver=ODBC+Driver+18+for+SQL+Server&Encrypt=no&TrustServerCertificate=yes

# --- App --------------------------------------------------------------------
APP_ENV=development                # `production` activa HSTS y cierra /docs
APP_SECRET_KEY=change-me-32-bytes-minimum   # rotar antes del go-live, generar con: python -c "import secrets; print(secrets.token_urlsafe(48))"
# Orígenes permitidos para CORS — separar por coma. En producción, poner el
# dominio público del frontend (ej. "https://presupuesto.tu-dominio").
APP_CORS_ORIGINS=http://localhost:5173

# --- Autenticación ----------------------------------------------------------
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=480   # 8 horas

# --- Storage de adjuntos ----------------------------------------------------
# `local` guarda en disco. Si el host es efímero o no tiene volumen
# persistente, considerá S3 / Azure Blob (no implementado todavía).
ATTACHMENT_STORAGE=local
ATTACHMENT_LOCAL_PATH=./storage/adjuntos

# --- Integración K2B (pendiente de implementación) --------------------------
K2B_API_BASE_URL=
K2B_API_TOKEN=
