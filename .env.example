# ============================================================================
# Variables de entorno del backend
# ============================================================================
# Para desarrollo local copiá este archivo a `.env` y editá los valores.
# Para Railway / cualquier PaaS, configurá estas variables en el dashboard del
# servicio. NO commitees `.env` con valores reales.

# --- Conexión a Postgres ----------------------------------------------------
# Railway provee `DATABASE_URL` con prefijo "postgresql://" — el código convierte
# a "postgresql+asyncpg://" automáticamente si hace falta. En desarrollo local
# usá el prefijo SQLAlchemy directo.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/presupuesto2027
DATABASE_URL_SYNC=postgresql+psycopg2://postgres:postgres@localhost:5432/presupuesto2027

# --- App --------------------------------------------------------------------
APP_ENV=development                # production en Railway → activa HSTS
APP_SECRET_KEY=change-me-32-bytes-minimum   # rotar antes del go-live, generar con: python -c "import secrets; print(secrets.token_urlsafe(48))"
# Orígenes permitidos para CORS — separar por coma. En Railway poner el dominio
# público del frontend (ej. "https://presupuesto-front.up.railway.app").
APP_CORS_ORIGINS=http://localhost:5173

# --- Autenticación ----------------------------------------------------------
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=480   # 8 horas

# --- Storage de adjuntos ----------------------------------------------------
# `local` guarda en disco (no persiste entre deploys de Railway sin volumen).
# Para producción real considerá S3 / Azure Blob.
ATTACHMENT_STORAGE=local
ATTACHMENT_LOCAL_PATH=./storage/adjuntos

# --- Integración K2B (pendiente de implementación) --------------------------
K2B_API_BASE_URL=
K2B_API_TOKEN=
